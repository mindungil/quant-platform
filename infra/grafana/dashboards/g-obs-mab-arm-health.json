{
  "uid": "g-obs-mab-arms",
  "title": "G-OBS — MAB Arm Health",
  "tags": ["quant", "g-obs", "mab"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Active arms (n > 0)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(mab_arm_n > 0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "orange" },
              { "value": 3, "color": "green" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Disabled arms",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(mab_arm_disabled == 1) OR vector(0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Total observations across all arms",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(mab_arm_n)", "refId": "A" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Cumulative reward (all arms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(mab_arm_total_reward)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "green" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Arm observation count (n)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "mab_arm_n", "legendFormat": "{{arm}}", "refId": "A" }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "orange" },
              { "value": 30, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Arm running mean reward",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "mab_arm_mean", "legendFormat": "{{arm}}", "refId": "A" }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": false },
      "fieldConfig": {
        "defaults": {
          "decimals": 5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "yellow" },
              { "value": 0.0005, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Per-arm running mean (time series)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "mab_arm_mean", "legendFormat": "{{arm}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 5,
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 1 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] } }
    },
    {
      "id": 8,
      "title": "Per-arm last update age (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "mab_arm_last_updated_seconds_ago", "legendFormat": "{{arm}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 3600, "color": "yellow" },
              { "value": 86400, "color": "red" }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 9,
      "title": "Per-arm cumulative reward (total_reward)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "mab_arm_total_reward", "legendFormat": "{{arm}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 4,
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] } }
    },
    {
      "id": 10,
      "title": "Arm snapshot — n, mean, std, total reward, last update age",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "mab_arm_n", "format": "table", "instant": true, "refId": "n" },
        { "expr": "mab_arm_mean", "format": "table", "instant": true, "refId": "mean" },
        { "expr": "mab_arm_std", "format": "table", "instant": true, "refId": "std" },
        { "expr": "mab_arm_total_reward", "format": "table", "instant": true, "refId": "tot" },
        { "expr": "mab_arm_last_updated_seconds_ago", "format": "table", "instant": true, "refId": "age" },
        { "expr": "mab_arm_disabled", "format": "table", "instant": true, "refId": "dis" }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "arm", "mode": "outer" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "Time 6": true, "job": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true, "job 5": true, "job 6": true, "instance": true, "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "instance 5": true, "instance 6": true } } }
      ]
    }
  ]
}
