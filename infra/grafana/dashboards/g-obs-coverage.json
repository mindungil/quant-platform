{
  "uid": "g-obs-coverage",
  "title": "G-OBS — Data Coverage",
  "tags": ["quant", "g-obs", "coverage", "venues"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Max tick age across venues (seconds)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "max(venue_tick_age_seconds)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 120, "color": "yellow" },
              { "value": 300, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Max cross-venue divergence",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "max(cross_venue_price_divergence)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.02, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Binance candle ingest rate (per min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(candle_ingest_total{status=\"success\"}[5m])) * 60", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "yellow" },
              { "value": 2.5, "color": "green" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Upbit candle ingest rate (per min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(upbit_candle_ingest_total{status=\"success\"}[5m])) * 60", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "yellow" },
              { "value": 2.5, "color": "green" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Per-venue tick age (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "venue_tick_age_seconds", "legendFormat": "{{venue}} / {{asset}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 1 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "transparent" },
              { "value": 120, "color": "yellow" },
              { "value": 300, "color": "red" }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 6,
      "title": "Cross-venue price divergence",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "cross_venue_price_divergence", "legendFormat": "{{base_asset}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 1 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.02, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 7,
      "title": "Candle ingest rate by venue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(candle_ingest_total{status=\"success\"}[5m])) * 60", "legendFormat": "binance (per min)", "refId": "A" },
        { "expr": "sum(rate(upbit_candle_ingest_total{status=\"success\"}[5m])) * 60", "legendFormat": "upbit (per min)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 8,
      "title": "Signal data staleness (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "signal_data_staleness_seconds", "legendFormat": "{{asset}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 9,
      "title": "Candle ingest failures (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum by (asset) (rate(candle_ingest_total{status=\"failed\"}[5m]))", "legendFormat": "binance {{asset}}", "refId": "A" },
        { "expr": "sum by (asset) (rate(upbit_candle_ingest_total{status=\"failed\"}[5m]))", "legendFormat": "upbit {{asset}}", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } }
    },
    {
      "id": 10,
      "title": "USDKRW reference rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "cross_venue_usdkrw_rate", "legendFormat": "USDKRW", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
