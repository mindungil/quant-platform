# =============================================================
# Quant Platform Environment
#
# All backend services run in a single container, so internal
# service-to-service URLs use localhost with per-service ports.
# =============================================================

# --- Infrastructure ---
NATS_URL=nats://nats:4222
POSTGRES_URL=postgresql+psycopg://postgres:postgres@db:5432/platform
TIMESCALE_URL=postgresql+psycopg://postgres:postgres@db:5432/market
POSTGRES_URL_MARKET=postgresql+psycopg://postgres:postgres@db:5432/market
REDIS_URL=redis://redis:6379/0

# --- Runtime ---
STRICT_RUNTIME=true
LIVE_TRADING_ENABLED=false
ALLOWED_LIVE_EXCHANGES=binance
DEFAULT_SHADOW_MODE=true
ENABLE_NATS=true
REALTIME_REPLAY_LIMIT=200

# --- Auth & Security ---
JWT_SECRET=dev-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=quant-auth-service
INTERNAL_ADMIN_SECRET=dev-internal-admin-secret
INTERNAL_ADMIN_HEADER_TTL_SECONDS=300
CREDENTIAL_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
BOOTSTRAP_ADMIN_EMAIL=admin@quant.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_DISPLAY_NAME=Quant Admin
BOOTSTRAP_ADMIN_TOKEN=dev-bootstrap-token

# --- JetStream Streams ---
MARKET_JETSTREAM_STREAM=MARKET_DATA
FEATURE_JETSTREAM_STREAM=FEATURE_DATA
SIGNAL_JETSTREAM_STREAM=SIGNAL_DATA
EXECUTION_JETSTREAM_STREAM=EXECUTION_DATA

# --- Signal & Agent ---
SIGNAL_THRESHOLD=0.6
EXTERNAL_SIGNAL_WEIGHT=0.35
ENABLE_LLM=true
LLM_MAX_TOKENS=500
AGENT_MAX_TOKENS=2000
AGENT_MAX_LOOPS=10
AGENT_CYCLE_INTERVAL=300
AGENT_MONITORED_ASSETS=BTCUSDT,ETHUSDT,SOLUSDT
# LLM은 OAuth 기반 — API 키 불필요 (유저가 /auth/claude/login 또는 /auth/codex/login으로 인증)
BINANCE_API_BASE_URL=https://api.binance.com

# --- Internal service URLs (all in the same backend container) ---
MARKET_DATA_BASE_URL=http://localhost:8001
FEATURE_STORE_BASE_URL=http://localhost:8002
SIGNAL_SERVICE_BASE_URL=http://localhost:8003
MEMORY_SERVICE_BASE_URL=http://localhost:8004
STRATEGY_REGISTRY_BASE_URL=http://localhost:8005
CRYPTO_AGENT_BASE_URL=http://localhost:8006
BACKTEST_SERVICE_BASE_URL=http://localhost:8007
EXCHANGE_ADAPTER_BASE_URL=http://localhost:8008
RISK_SERVICE_BASE_URL=http://localhost:8009
CREDENTIAL_STORE_BASE_URL=http://localhost:8010
ORDER_SERVICE_BASE_URL=http://localhost:8011
PORTFOLIO_SERVICE_BASE_URL=http://localhost:8012
STATISTICS_SERVICE_BASE_URL=http://localhost:8013
API_GATEWAY_BASE_URL=http://localhost:8017
AUTH_SERVICE_BASE_URL=http://localhost:8019
EXTERNAL_DATA_SERVICE_BASE_URL=http://localhost:8020
LLM_GATEWAY_BASE_URL=http://localhost:8021

# --- Frontend (browser-side) ---
NEXT_PUBLIC_GATEWAY_BASE_URL=http://localhost:8017

# --- Host URLs (for operator scripts running outside containers) ---
HOST_API_GATEWAY_BASE_URL=http://localhost:8017
HOST_AUTH_SERVICE_BASE_URL=http://localhost:8019
HOST_MARKET_DATA_BASE_URL=http://localhost:8001
HOST_FEATURE_STORE_BASE_URL=http://localhost:8002
HOST_SIGNAL_SERVICE_BASE_URL=http://localhost:8003
HOST_CRYPTO_AGENT_BASE_URL=http://localhost:8006
HOST_ORDER_SERVICE_BASE_URL=http://localhost:8011
HOST_PORTFOLIO_SERVICE_BASE_URL=http://localhost:8012
HOST_STATISTICS_SERVICE_BASE_URL=http://localhost:8013
HOST_RISK_SERVICE_BASE_URL=http://localhost:8009
HOST_EXCHANGE_ADAPTER_BASE_URL=http://localhost:8008
HOST_FRONTEND_BASE_URL=http://localhost:8018
